# ============================================================
# 3939SPOT 環境変数サンプル
# このファイルをコピーして .env を作成し、実際の値を設定してください。
# .env はGitにコミットしないでください（.gitignore で除外済み）。
# ============================================================

# ── Flask 基本設定 ──────────────────────────────────────────
# 動作環境: development / production / testing
FLASK_ENV=development

# セッション署名・CSRF保護などに使用する秘密鍵
# 本番環境では必ず長くランダムな文字列を設定すること
SECRET_KEY=your-secret-key-here

# ── データベース ────────────────────────────────────────────
# PostgreSQL 接続URL
# ローカル例: postgresql://postgres:postgres@localhost:5432/spot3939
# Cloud SQL 例: postgresql+pg8000://<user>:<pass>@/<db>?unix_sock=/cloudsql/<project>:<region>:<instance>/.s.PGSQL.5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/spot3939

# ── Redis ──────────────────────────────────────────────────
# Redis 接続URL（セッション・レート制限・キャッシュに使用）
# ローカル例: redis://localhost:6379/0
# Upstash 例: rediss://<password>@<host>:6380/0
REDIS_URL=redis://localhost:6379/0

# ── LINE Login API ─────────────────────────────────────────
# LINE Developers コンソールで取得するLINEログイン用チャネル情報
LINE_CHANNEL_ID=your-line-channel-id
LINE_CHANNEL_SECRET=your-line-channel-secret

# OAuthコールバックURL（LINE Developersコンソールに登録したものと一致させること）
# ローカル例: http://localhost:5000/auth/line/callback
LINE_REDIRECT_URI=https://your-domain.com/auth/line/callback

# ── LINE Messaging API ──────────────────────────────────────
# Messaging API チャネル（LINEボット通知に使用）
LINE_MESSAGING_CHANNEL_SECRET=your-messaging-channel-secret
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=your-messaging-channel-access-token

# ── Google Maps API ─────────────────────────────────────────
# 提携店マップ表示に使用
# Google Cloud Console で Maps JavaScript API を有効にして取得
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── メール送信 ───────────────────────────────────────────────
# SendGrid を使用する場合
SENDGRID_API_KEY=your-sendgrid-api-key

# SMTP を使用する場合（SendGrid の代わりに設定）
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASSWORD=your-smtp-password

# ── Google Cloud Platform ────────────────────────────────────
# GCP プロジェクトID（Cloud Run / Cloud SQL / GCS 等で使用）
GCP_PROJECT_ID=your-gcp-project-id

# Cloud Storage バケット名（静的アセット配信に使用）
GCS_BUCKET_NAME=your-gcs-bucket-name
