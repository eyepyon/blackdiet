# ============================================================
# 3939SPOT .gitignore
# ============================================================

# ── 環境変数（秘密情報を含むため必ずGit管理外とする） ──────────
.env
.env.local
.env.*.local

# ── Python ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-log.txt
pip-delete-this-directory.txt

# ── 仮想環境 ────────────────────────────────────────────────
venv/
.venv/
env/
.env/

# ── pytest / テスト ─────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover

# ── Flask ───────────────────────────────────────────────────
instance/
flask_session/

# ── SQLite（ローカル開発用フォールバック） ─────────────────────
*.db
*.sqlite3

# ── IDE / エディタ ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── macOS ───────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Windows ─────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Terraform ───────────────────────────────────────────────
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/.terraform.lock.hcl

# ── Docker ──────────────────────────────────────────────────
*.log

# ── GCP 認証情報 ─────────────────────────────────────────────
*.json
!package.json
!composer.json
service-account*.json
credentials*.json
